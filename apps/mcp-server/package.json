{
  "name": "@casperproof/mcp-server",
  "version": "0.1.0",
  "description": "Casper MCP server exposing CasperProof oracle + insurance tools to agents.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "casperproof-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage .turbo *.tsbuildinfo",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@casperproof/commitment": "workspace:*",
    "@casperproof/casper-sdk": "workspace:*",
    "@casperproof/agent": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@casperproof/config": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^26.1.1"
  }
}
