{
  "name": "casperproof",
  "version": "0.1.0",
  "private": true,
  "description": "CasperProof — the verifiable AI oracle and trust layer for the agent economy on Casper.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "gen:golden": "tsx scripts/gen-golden.ts",
    "deploy:testnet": "tsx scripts/deploy-testnet.ts",
    "fund:testnet": "tsx scripts/fund-testnet.ts",
    "seed": "tsx scripts/seed-demo.ts"
  },
  "devDependencies": {
    "@casperproof/config": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.5",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0"
  },
  "pnpm": {
    "overrides": {}
  }
}
