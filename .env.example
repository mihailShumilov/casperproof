# ──────────────────────────────────────────────────────────────────────────
# CasperProof environment — copy to .env (`cp .env.example .env`) then `make up`.
# Every value below has a working local default; only the SECRETS marked
# (REQUIRED FOR TESTNET) must be supplied for a real Casper Testnet deploy.
# ──────────────────────────────────────────────────────────────────────────

# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Host ports (unique 29xxx block to avoid colliding with other local stacks) ──
# These are the HOST-side published ports for `make up`. In-container ports stay
# standard (e.g. ollama 11434, minio 9000) so service-to-service URLs below are
# unchanged. Override any of these if 29xxx is also taken on your machine.
WEB_PORT=29300
MARKETING_PORT=29301
OLLAMA_PORT=29434
MINIO_API_PORT=29900
MINIO_CONSOLE_PORT=29901

# ── Casper network / deploy ──────────────────────────────────────────────────
# Local default points at the public testnet RPC; deploy is mocked unless keys present.
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
# (REQUIRED FOR TESTNET) PEM secret key used by deploy/seed scripts. Leave blank for mock.
CASPER_SECRET_KEY_PATH=
# Populated by `make deploy-testnet` (deployer service writes these to .env.local):
ATTESTATION_REGISTRY_HASH=
INSURANCE_HASH=
STAKE_TOKEN_HASH=
USDC_TOKEN_HASH=
# Live deploy runs the Odra livenet binary (contracts/bin/livenet.rs). These ODRA_CASPER_LIVENET_*
# vars are auto-derived from the values above + CSPR_CLOUD_TOKEN; set them only to override.
#   ODRA_CASPER_LIVENET_SECRET_KEY_PATH  (defaults to CASPER_SECRET_KEY_PATH)
#   ODRA_CASPER_LIVENET_NODE_ADDRESS     (defaults to https://node.testnet.cspr.cloud)
#   ODRA_CASPER_LIVENET_CHAIN_NAME       (defaults to CASPER_NETWORK_NAME)
#   ODRA_CASPER_LIVENET_EVENTS_URL       (defaults to <node>/events)
# Knobs: CP_LIVENET_STEP=deploy|all (default all) · CP_DRY_RUN=true · CP_FORCE_MOCK=true

# ── CSPR.cloud (queries + streaming) ─────────────────────────────────────────
CSPR_CLOUD_REST_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_STREAMING_URL=wss://streaming.testnet.cspr.cloud
# (REQUIRED FOR LIVE DATA) access token. Without it, the SDK falls back to mock mode.
CSPR_CLOUD_TOKEN=

# ── CSPR.click (wallet) ──────────────────────────────────────────────────────
NEXT_PUBLIC_CSPR_CLICK_APP_ID=casperproof
NEXT_PUBLIC_CSPR_CLICK_APP_NAME=CasperProof

# ── x402 facilitator (agent micropayments) ───────────────────────────────────
# Empty ⇒ local mock verifier (offline 402→pay→serve). For real micropayments set the
# Casper facilitator URL, e.g. https://facilitator.testnet.casper.network (see SETUP_NEEDED.md).
X402_FACILITATOR_URL=
X402_PRICE_USD=0.01
X402_PAY_TO=casperproof-treasury
X402_SERVER_PORT=29402

# ── MCP server ───────────────────────────────────────────────────────────────
MCP_SERVER_PORT=29405
MCP_TRANSPORT=stdio

# ── Agent runtime (zero-cost) ─────────────────────────────────────────────────
# ollama (default) | none (pure deterministic) | openai | anthropic (off by default)
LLM_BACKEND=ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
AGENT_POLL_INTERVAL_MS=5000

# ── S3-compatible payload store ──────────────────────────────────────────────
# Local default = MinIO from docker-compose. Prod = Cloudflare R2 / AWS S3.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=casperproof-payloads
S3_ACCESS_KEY=casperproof
S3_SECRET_KEY=casperproof-secret
S3_FORCE_PATH_STYLE=true
# Host-facing payload URL (matches MINIO_API_PORT). In-container S3_ENDPOINT stays minio:9000.
S3_PUBLIC_URL=http://localhost:29900

# ── Web / marketing ──────────────────────────────────────────────────────────
# Host-facing URLs (match WEB_PORT / MARKETING_PORT / X402_SERVER_PORT above).
NEXT_PUBLIC_APP_URL=http://localhost:29300
NEXT_PUBLIC_MARKETING_URL=http://localhost:29301
NEXT_PUBLIC_X402_SERVER_URL=http://localhost:29402
NEXT_PUBLIC_SITE_URL=https://casperproof.com
