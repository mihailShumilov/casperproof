# ──────────────────────────────────────────────────────────────────────────
# CasperProof environment — copy to .env (`cp .env.example .env`) then `make up`.
# Every value below has a working local default; only the SECRETS marked
# (REQUIRED FOR TESTNET) must be supplied for a real Casper Testnet deploy.
# ──────────────────────────────────────────────────────────────────────────

# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Casper network / deploy ──────────────────────────────────────────────────
# Local default points at the public testnet RPC; deploy is mocked unless keys present.
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
# (REQUIRED FOR TESTNET) PEM secret key used by deploy/seed scripts. Leave blank for mock.
CASPER_SECRET_KEY_PATH=
# Populated by `make deploy-testnet` (deployer service writes these to .env.local):
ATTESTATION_REGISTRY_HASH=
INSURANCE_HASH=
STAKE_TOKEN_HASH=
USDC_TOKEN_HASH=

# ── CSPR.cloud (queries + streaming) ─────────────────────────────────────────
CSPR_CLOUD_REST_URL=https://api.testnet.cspr.cloud
CSPR_CLOUD_STREAMING_URL=wss://streaming.testnet.cspr.cloud
# (REQUIRED FOR LIVE DATA) access token. Without it, the SDK falls back to mock mode.
CSPR_CLOUD_TOKEN=

# ── CSPR.click (wallet) ──────────────────────────────────────────────────────
NEXT_PUBLIC_CSPR_CLICK_APP_ID=casperproof
NEXT_PUBLIC_CSPR_CLICK_APP_NAME=CasperProof

# ── x402 facilitator (agent micropayments) ───────────────────────────────────
X402_FACILITATOR_URL=https://facilitator.testnet.casper.network
X402_PRICE_USD=0.01
X402_PAY_TO=casperproof-treasury
X402_SERVER_PORT=8402

# ── MCP server ───────────────────────────────────────────────────────────────
MCP_SERVER_PORT=8405
MCP_TRANSPORT=stdio

# ── Agent runtime (zero-cost) ─────────────────────────────────────────────────
# ollama (default) | none (pure deterministic) | openai | anthropic (off by default)
LLM_BACKEND=ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
AGENT_POLL_INTERVAL_MS=5000

# ── S3-compatible payload store ──────────────────────────────────────────────
# Local default = MinIO from docker-compose. Prod = Cloudflare R2 / AWS S3.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=casperproof-payloads
S3_ACCESS_KEY=casperproof
S3_SECRET_KEY=casperproof-secret
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:9000

# ── Web / marketing ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3001
NEXT_PUBLIC_X402_SERVER_URL=http://localhost:8402
NEXT_PUBLIC_SITE_URL=https://casperproof.com
