{
  "name": "@casperproof/agent",
  "version": "0.1.0",
  "description": "CasperProof zero-cost agent runtime: risk-scorer, claim-oracle, attestor, verifier, S3 store, Ollama loop.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "casperproof-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage .turbo *.tsbuildinfo",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@casperproof/commitment": "workspace:*",
    "@casperproof/casper-sdk": "workspace:*",
    "@aws-sdk/client-s3": "^3.726.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@casperproof/config": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.5"
  }
}
